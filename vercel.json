{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/api/espn-events",
      "destination": "https://site.api.espn.com/apis/site/v2/sports/football/nfl/scoreboard"
    },
    {
      "source": "/api/espn-standings",
